# ============================================
# ChannelSync Environment Variables
# Copy to .env.local and fill in values
# ============================================

# Shopify App (Required)
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret

# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# App URL (Required)
NEXT_PUBLIC_APP_URL=https://channelsync.vercel.app

# Amazon SP-API (Optional - for Amazon integration)
AMAZON_APP_ID=your_amazon_app_id
AMAZON_CLIENT_ID=your_amazon_client_id
AMAZON_CLIENT_SECRET=your_amazon_client_secret
# AWS credentials for SP-API signing
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_ROLE_ARN=your_sp_api_role_arn

# Etsy API (Optional - for Etsy integration)
ETSY_API_KEY=your_etsy_api_key

# Billing (set to false for production)
SHOPIFY_BILLING_TEST=false
