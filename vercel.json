{
  "crons": [
    {
      "path": "/api/cron/sync-orders?frequency=hourly",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/sync-orders?frequency=daily",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/check-subscriptions",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/onboarding",
      "schedule": "0 */6 * * *"
    }
  ]
}
